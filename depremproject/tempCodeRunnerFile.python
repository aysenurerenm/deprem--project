GRID_W = 15
GRID_H = 11

def generate_grid(w, h):
    grid = [[True for _ in range(w)] for _ in range(h)]
    for y in range(1, h, 2):
        for x in range(1, w, 2):
            grid[y][x] = False
            if x+1 < w: grid[y][x+1] = False
            if y+1 < h: grid[y+1][x] = False
    return grid
generate_grid(GRID_W, GRID_H)